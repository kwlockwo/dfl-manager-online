<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%p %m%n%ex</pattern>
        </encoder>
    </appender>

    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
        <http>
            <url>${LOKI_URL:-http://localhost:3100}/loki/api/v1/push</url>
        </http>
        <format>
            <label>
                <pattern>app=DFLManagerOnline,level=%level,handler=%mdc{handler}</pattern>
            </label>
            <message>
                <pattern>%p %m%n%ex</pattern>
            </message>
        </format>
    </appender>

    <logger name="stdout-logger" level="${DFLMNGR_LOG_LEVEL:-info}" additivity="false">
        <appender-ref ref="STDOUT"/>
    </logger>

    <logger name="loki-logger" level="${DFLMNGR_LOG_LEVEL:-info}" additivity="false">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="LOKI"/>
    </logger>

    <root level="${DFLMNGR_LOG_LEVEL:-info}">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>

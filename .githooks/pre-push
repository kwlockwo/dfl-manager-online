#!/bin/bash
#
# Git pre-push hook to run tests before allowing a push
# This ensures all tests pass before code is pushed to the remote
#
# To install:
#   git config core.hooksPath .githooks
#   chmod +x .githooks/pre-push
#

echo "🧪 Running all tests before push..."

# Run all tests
mvn test -q

# Capture the exit code
TEST_RESULT=$?

if [ $TEST_RESULT -ne 0 ]; then
    echo ""
    echo "❌ Tests failed! Push aborted."
    echo ""
    echo "Fix the failing tests and try again."
    echo "To skip this check (not recommended), use: git push --no-verify"
    exit 1
fi

echo "✅ All tests passed! Proceeding with push..."
exit 0
